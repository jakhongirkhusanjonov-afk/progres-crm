generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Foydalanuvchilar (Adminlar, o'qituvchilar, talabalar)
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  username      String    @unique
  password      String    // bcrypt hash
  plainPassword String?   // AES encrypted (faqat SUPER_ADMIN ko'rishi uchun)
  fullName      String?
  role          UserRole  @default(ADMIN)
  phone         String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Admin yaratgan recordlar
  createdStudents Student[]    @relation("CreatedBy")
  createdTeachers Teacher[]    @relation("CreatedBy")
  createdPayments Payment[]    @relation("CreatedBy")
  notifications   Notification[]

  // O'qituvchi yoki Talaba sifatida bog'lanish
  student       Student?   @relation("UserStudent")
  teacher       Teacher?   @relation("UserTeacher")
  admin         Admin?
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  ACCOUNTANT
  TEACHER
  STUDENT
}

// Talabalar
model Student {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  phone           String    // @unique olib tashlandi - bir oiladan bir nechta farzand bo'lishi mumkin
  parentPhone     String?
  dateOfBirth     DateTime?
  gender          Gender?
  enrollmentDate  DateTime  @default(now())
  status          StudentStatus @default(ACTIVE)
  createdById     String
  createdBy       User      @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // User account bog'lanishi (login uchun)
  userId          String?   @unique
  user            User?     @relation("UserStudent", fields: [userId], references: [id])

  groupStudents   GroupStudent[]
  attendances     Attendance[]
  payments        Payment[]
  testResults     TestResult[]
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  GRADUATED
  SUSPENDED
  DROPPED
}

// O'qituvchilar
model Teacher {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  middleName    String?
  phone         String    // @unique olib tashlandi - bir xil telefon bo'lishi mumkin
  email         String?   @unique
  dateOfBirth   DateTime?
  address       String?
  specialization String?
  experience    Int?
  education     String?
  salary        Decimal?
  status        TeacherStatus @default(ACTIVE)
  photo         String?
  hireDate      DateTime  @default(now())
  createdById   String
  createdBy     User      @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // User account bog'lanishi (login uchun)
  userId        String?   @unique
  user          User?     @relation("UserTeacher", fields: [userId], references: [id])

  groups        Group[]
  schedules     Schedule[]
  salaryPayments SalaryPayment[]
  teacherCourses TeacherCourse[]
}

// Adminlar (User bilan bog'langan)
model Admin {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  phone     String   // @unique olib tashlandi
  email     String?
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// O'qituvchi-Kurs bog'lanishi (foiz bilan)
model TeacherCourse {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  percentage  Int      @default(50) // 40-60% oralig'ida
  createdAt   DateTime @default(now())

  @@unique([teacherId, courseId])
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
}

// Kurslar
model Course {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int?     // soatda
  price       Decimal
  level       String?  // Beginner, Intermediate, Advanced
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groups         Group[]
  teacherCourses TeacherCourse[]
}

// Guruhlar
model Group {
  id           String      @id @default(cuid())
  name         String
  courseId     String
  course       Course      @relation(fields: [courseId], references: [id])
  teacherId    String
  teacher      Teacher     @relation(fields: [teacherId], references: [id])
  startDate    DateTime
  status       GroupStatus @default(ACTIVE)
  roomNumber   String?
  branch       String?     // Filial
  price        Decimal?    // Guruh narxi (default kurs narxidan)
  scheduleDays String?     // Dars kunlari: "1,3,5" (Dush, Chor, Juma)
  startTime    String      // Dars boshlanish vaqti: "14:00" formatida
  endTime      String      // Dars tugash vaqti: "16:00" formatida
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  groupStudents GroupStudent[]
  schedules     Schedule[]
  attendances   Attendance[]
  testResults   TestResult[]
  payments      Payment[]
}

enum GroupStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// Guruh-Talaba bog'lanishi
model GroupStudent {
  id              String   @id @default(cuid())
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollDate      DateTime @default(now())
  status          GroupStudentStatus @default(ACTIVE)
  price           Decimal? // Individual narx (default guruh narxi)
  discountReason  String?  // Chegirma sababi

  @@unique([groupId, studentId])
}

enum GroupStudentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

// Dars jadvali
model Schedule {
  id         String   @id @default(cuid())
  groupId    String
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  dayOfWeek  Int      // 0-6 (Yakshanba-Shanba)
  startTime  String   // "09:00"
  endTime    String   // "11:00"
  roomNumber String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Davomad
model Attendance {
  id        String           @id @default(cuid())
  groupId   String
  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([groupId, studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// To'lovlar
model Payment {
  id          String        @id @default(cuid())
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?        @relation(fields: [groupId], references: [id])
  forMonth    String?       // "Yanvar", "Fevral", ...
  forYear     Int?          // 2025, 2026, ...
  amount      Decimal
  paymentDate DateTime      @default(now())
  paymentType PaymentType
  method      PaymentMethod
  description String?
  createdById String
  createdBy   User          @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum PaymentType {
  TUITION
  REGISTRATION
  EXAM
  MATERIAL
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  PAYME
  CLICK
  UZUM
}

// O'qituvchi ish haqi to'lovlari
model SalaryPayment {
  id          String        @id @default(cuid())
  teacherId   String
  teacher     Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  amount      Decimal
  paymentDate DateTime
  period      String        // "2024-01" (yil-oy)
  method      PaymentMethod
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Test natijalari
model TestResult {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  testName  String
  score     Decimal
  maxScore  Decimal
  testDate  DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Bildirishnomalar (SMS/Email)
model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  recipient  String           // telefon raqami yoki email
  subject    String?
  message    String
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum NotificationType {
  SMS
  EMAIL
  BOTH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// Xarajatlar
model Expense {
  id          String        @id @default(cuid())
  category    String
  amount      Decimal
  description String
  expenseDate DateTime
  method      PaymentMethod
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
